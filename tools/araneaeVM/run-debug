#!/bin/bash

set -e

ASM_SOURCE=$1
ARANEAE_SCRIPT_DIR=$(dirname ${BASH_SOURCE[0]})

ASM_DISPATCH_SCRIPT_OUT=`$ARANEAE_SCRIPT_DIR/asm-dispatch.sh $ASM_SOURCE`
echo ASM_DISPATCH_SCRIPT_OUT=\"$ASM_DISPATCH_SCRIPT_OUT\"
ASM_DISPATCH_UUID=`echo "$ASM_DISPATCH_SCRIPT_OUT" | grep -oE '[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}'`

GET_BINARY_MODULE_SCRIPT_OUT=`$ARANEAE_SCRIPT_DIR/asm-get.sh $ASM_DISPATCH_UUID`
echo GET_BINARY_MODULE_SCRIPT_OUT=\"$GET_BINARY_MODULE_SCRIPT_OUT\"

$ARANEAE_SCRIPT_DIR/run-debug.sh ./out.ptptb
