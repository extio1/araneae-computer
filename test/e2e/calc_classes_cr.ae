method readChar();
method writeChar(CharValue);

method readOp()
begin
  Op := readChar();
  while Op == ' ' || Op == '\r' || Op == '\n'; do
  begin
    Op := readChar();
  end;
  ret Op;
end;

method readInt()
begin
  Res := 0;
  
  Digit := readChar();
  while Digit == ' ' || Digit == '\r' || Digit == '\n'; do
  begin
    Digit := readChar();
  end;
  
  while Digit != '\r' && Digit != '\n'; do
  begin
    Res := Res * 10 + (Digit - 48);
    Digit := readChar();
  end;
  
  ret Res;
end;

method printUInt(Value)
begin
  Divider := 1;

  Tmp := Value;
  while Tmp >= 10; do
  begin
    Divider := Divider * 10;
    Tmp := Tmp / 10;
  end;

  while Divider > 0; do
  begin
    Symbol := Value / Divider + 48;
    writeChar(Symbol);
    Value := Value % Divider;
    Divider := Divider / 10;
  end;
  ret;
end;

method printInt(Value)
begin
  if Value < 0; then
  begin
    writeChar('-');
    Value := ~Value + 1;
  end;

  printUInt(Value);
  writeChar('\r');
  writeChar('\n');
  ret;
end;

class Accumulator
  var Value;
      Value2;
begin
  public method Accumulator() 
  begin 
    this.Value := 0;
    this.Value2 := 0;
  end;

  public method get()
  begin
    ret this.Value;
  end;

  public method set(NewValue)
  begin
    this.Value := NewValue;
  end;
end;

class Calculator : Accumulator 
  var Value1;
begin
  public method Calculator() 
  begin
    this.Value1 := 1;
  end;

  public method add(Term)
  begin
    this.Value := this.Value + Term;
  end;

  public method sub(Term)
  begin
    this.Value := this.Value - Term;
  end;

  public method mul(Mult)
  begin
    this.Value := this.Value * Mult;
  end;

  public method div(Mult)
  begin
    this.Value := this.Value / Mult;
  end;
end;


method main()
begin
  PrevVal := 0;
  Result := 0;

  Calc := Calculator();

  while true; do 
  begin
    Op := readOp();

    if Op == 'q'; then
    begin
      break;
    end;

    InputVal := readInt();

    if Op == '+'; then
		begin
			Calc.add(InputVal);
		end;
    if Op == '-'; then
    begin
      Calc.sub(InputVal);
    end;
    if Op == '*'; then
    begin
      Calc.mul(InputVal);
    end;
    if Op == '/'; then
    begin
      Calc.div(InputVal);
    end;

    printInt(Calc.get());
  end;

  ret Result;
end;
